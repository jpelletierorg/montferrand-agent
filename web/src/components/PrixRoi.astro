---
---

<section id="prix" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4 md:px-8">
    <h2 class="font-serif text-3xl md:text-4xl font-bold text-primary text-center tracking-tight">
      Essayez sans risque pendant 30 jours. 100 % satisfait ou remboursé.
    </h2>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-2 gap-8 items-start">

      <!-- Pricing card -->
      <div class="relative bg-primary text-primary-foreground rounded-xl p-8 shadow-xl">
        <span class="absolute top-4 right-4 text-xs font-semibold uppercase tracking-wider bg-accent text-accent-foreground px-3 py-1 rounded-full">
          Nouveau
        </span>

        <p class="text-sm font-medium text-primary-foreground/70 mt-2">Forfait Unique</p>

        <div class="mt-4 flex items-baseline gap-1">
          <span class="font-serif text-5xl md:text-6xl font-bold">59,99 $</span>
          <span class="text-lg text-primary-foreground/60">/ mois</span>
        </div>

        <ul class="mt-8 space-y-3">
          <li class="flex items-center gap-2 text-sm">
            <svg class="w-5 h-5 text-accent flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            30 jours gratuits
          </li>
          <li class="flex items-center gap-2 text-sm">
            <svg class="w-5 h-5 text-accent flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Aucun contrat à long terme
          </li>
          <li class="flex items-center gap-2 text-sm">
            <svg class="w-5 h-5 text-accent flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Conversations SMS illimitées
          </li>
          <li class="flex items-center gap-2 text-sm">
            <svg class="w-5 h-5 text-accent flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Support technique local
          </li>
        </ul>

        <a href="#onboarding" class="mt-8 inline-flex items-center justify-center w-full px-6 py-3.5 text-sm font-semibold rounded-full bg-accent text-accent-foreground hover:bg-accent-hover transition-colors">
          Commencer l'essai gratuit
        </a>

        <!-- Guarantee badge -->
        <div class="mt-5 flex items-center justify-center gap-2 pt-5 border-t border-primary-foreground/15">
          <svg class="w-5 h-5 text-accent flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11.5 14.5 15.5 10"/></svg>
          <span class="text-sm text-primary-foreground/80">Garantie satisfait ou remboursé — 30 jours</span>
        </div>
      </div>

      <!-- ROI calculator -->
      <div>
        <h3 class="font-serif text-2xl font-bold text-primary">Le calcul est simple</h3>

        <div class="mt-6 space-y-3">
          <div class="bg-card rounded-lg p-4 shadow-sm border border-border">
            <div class="flex items-center justify-between">
              <span class="font-semibold text-sm">1 appel de plus / mois</span>
              <span class="text-xs font-semibold uppercase tracking-wider text-green-600 bg-green-50 px-2.5 py-1 rounded-full">Rentable</span>
            </div>
            <p class="mt-1 text-sm text-muted-foreground">Le système se paie tout seul avec un seul appel de service récupéré.</p>
          </div>

          <div class="bg-card rounded-lg p-4 shadow-sm border border-border">
            <div class="flex items-center justify-between">
              <span class="font-semibold text-sm">3 appels de plus / mois</span>
              <span class="font-serif text-lg font-bold text-primary">~750 $</span>
            </div>
            <p class="mt-1 text-sm text-muted-foreground">De revenus supplémentaires générés pendant que vous dormez.</p>
          </div>

          <div class="bg-card rounded-lg p-4 shadow-sm border border-border">
            <div class="flex items-center justify-between">
              <span class="font-semibold text-sm">5 appels de plus / mois</span>
              <span class="font-serif text-lg font-bold text-primary">~1 250 $</span>
            </div>
            <p class="mt-1 text-sm text-muted-foreground">De revenus supplémentaires générés pendant que vous dormez.</p>
          </div>
        </div>

        <p class="mt-4 text-xs text-muted-foreground italic">
          * Basé sur une estimation prudente de 250 $ par appel de service résidentiel.
        </p>
      </div>
    </div>
  </div>
</section>
