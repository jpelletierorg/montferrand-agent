---
---

<footer class="bg-primary text-primary-foreground pt-12 pb-6">
  <div class="mx-auto max-w-6xl px-4 md:px-8">
    <div class="flex flex-col md:flex-row md:justify-between gap-8">

      <!-- Brand -->
      <div>
        <a href="/" class="font-serif text-xl font-bold text-primary-foreground no-underline">Montferrand</a>
        <p class="mt-2 text-sm text-primary-foreground/60 max-w-xs">
          L'assistant de réservation après les heures pour les plombiers du Québec.
        </p>
      </div>

      <!-- Links -->
      <div class="flex flex-col gap-2">
        <a href="/contact" class="text-sm text-primary-foreground/70 hover:text-primary-foreground transition-colors">Contact</a>
        <a href="/confidentialite" class="text-sm text-primary-foreground/70 hover:text-primary-foreground transition-colors">Confidentialité</a>
        <span class="text-sm text-primary-foreground/40">Conditions</span>
      </div>

      <!-- Badge -->
      <div class="flex items-start gap-2">
        <span class="text-sm font-medium text-primary-foreground/80">Fait au Québec</span>
        <span class="text-lg">⚜</span>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-primary-foreground/10 text-center">
      <p class="text-xs text-primary-foreground/40">
        &copy; {new Date().getFullYear()} Montferrand. Tous droits réservés.
      </p>
    </div>
  </div>
</footer>
