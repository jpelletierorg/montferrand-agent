---
---

<section id="commencer" class="py-20 md:py-28 bg-primary">
  <div class="mx-auto max-w-6xl px-4 md:px-8">

    <!-- Section header -->
    <p class="text-accent font-bold text-sm uppercase tracking-widest text-center">Commencer</p>
    <h2 class="mt-3 font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-white text-center tracking-tight leading-tight max-w-3xl mx-auto">
      Parlons-en. Votre agent est prêt en 24&nbsp;heures.
    </h2>

    <!-- Two-column layout -->
    <div class="mt-14 flex flex-col lg:flex-row items-start gap-12 lg:gap-16">

      <!-- Left column: founder + vision -->
      <div class="lg:w-[55%] w-full">

        <!-- Founder intro -->
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6">
          <img
            src="/assets/founder.png"
            alt="Jonathan Pelletier — Fondateur de Montferrand"
            class="w-32 h-32 md:w-40 md:h-40 object-cover object-top rounded-2xl flex-shrink-0"
            width="896"
            height="1200"
            loading="lazy"
          />
          <div>
            <h3 class="font-serif text-xl md:text-2xl font-bold text-white">Jonathan Pelletier</h3>
            <p class="text-accent text-sm font-medium mt-1">Fondateur de Montferrand</p>
            <p class="mt-3 text-sm md:text-base text-white/60 leading-relaxed">
              J'ai bâti Montferrand parce que les plombiers du Québec méritent les mêmes outils que les grandes entreprises. C'est pas compliqué&nbsp;: vous faites de la plomberie, je m'occupe de la techno.
            </p>
          </div>
        </div>

        <!-- Divider -->
        <div class="border-t border-white/10 my-8"></div>

        <!-- Advantage bullets -->
        <h4 class="text-sm font-bold text-accent uppercase tracking-wider mb-5">Pourquoi Montferrand</h4>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <p class="text-sm text-white/70 leading-relaxed">
              <strong class="text-white">~70 % des appels en dehors des heures de bureau restent sans réponse</strong> — chaque appel manqué, c'est un client qui appelle votre compétiteur.
            </p>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            <p class="text-sm text-white/70 leading-relaxed">
              <strong class="text-white">Les agents IA sont l'avenir des métiers.</strong> La techno est prête aujourd'hui — ceux qui embarquent maintenant ont une longueur d'avance.
            </p>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4"/><path d="m6.34 6.34 2.83 2.83"/><path d="M2 12h4"/><path d="m6.34 17.66 2.83-2.83"/><path d="M12 18v4"/><path d="m17.66 17.66-2.83-2.83"/><path d="M18 12h4"/><path d="m17.66 6.34-2.83 2.83"/></svg>
            <p class="text-sm text-white/70 leading-relaxed">
              <strong class="text-white">Ce n'est que le début.</strong> Agent vocal, comptes recevables, approvisionnement en pièces — tout ça s'en vient.
            </p>
          </li>
        </ul>

      </div>

      <!-- Right column: contact card -->
      <div class="lg:w-[45%] w-full">
        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8 md:p-10">

          <h3 class="font-serif text-xl md:text-2xl font-bold text-white">
            On jase?
          </h3>
          <p class="mt-3 text-sm text-white/50 leading-relaxed">
            On jase 15 minutes, je configure votre agent, et vous êtes opérationnel en 24h.
          </p>

          <!-- Contact info -->
          <div class="mt-8 space-y-5">

            <!-- Phone -->
            <a href="tel:+14389364563" class="flex items-center gap-4 group">
              <div class="w-11 h-11 rounded-full bg-accent/15 flex items-center justify-center flex-shrink-0 group-hover:bg-accent/25 transition-colors">
                <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-white group-hover:text-accent transition-colors">+1 (438) 936-4563</p>
                <p class="text-xs text-white/40">Appel ou texto</p>
              </div>
            </a>

            <!-- Email -->
            <a href="mailto:bonjour@montferrand.ca" class="flex items-center gap-4 group">
              <div class="w-11 h-11 rounded-full bg-accent/15 flex items-center justify-center flex-shrink-0 group-hover:bg-accent/25 transition-colors">
                <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-white group-hover:text-accent transition-colors">bonjour@montferrand.ca</p>
                <p class="text-xs text-white/40">Réponse en moins de 2h</p>
              </div>
            </a>

          </div>

          <!-- Divider -->
          <div class="border-t border-white/10 my-8"></div>

          <!-- Quick-start CTA -->
          <a href="tel:+14389364563" class="inline-flex items-center justify-center w-full px-6 py-4 text-base font-semibold rounded-full bg-accent text-accent-foreground hover:bg-accent-hover transition-colors shadow-md">
            Appelez-moi maintenant
          </a>

          <p class="mt-4 text-center text-xs text-white/30">
            Aucun engagement. Aucune carte de crédit.
          </p>

        </div>
      </div>

    </div>
  </div>
</section>
