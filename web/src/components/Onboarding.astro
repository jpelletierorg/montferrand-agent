---
---

<section id="onboarding" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4 md:px-8">
    <h2 class="font-serif text-3xl md:text-4xl font-bold text-primary text-center tracking-tight">
      Prêt à essayer? On s'occupe de tout.
    </h2>
    <p class="mt-3 text-center text-muted-foreground max-w-lg mx-auto">
      Une configuration clé en main en 4 étapes simples.
    </p>

    <!-- Vertical timeline -->
    <div class="mt-14 max-w-xl mx-auto relative">
      <!-- Vertical line -->
      <div class="absolute left-6 top-0 bottom-0 w-px bg-border md:left-8"></div>

      <!-- Step 1 -->
      <div class="relative flex gap-4 md:gap-6 pb-8">
        <div class="relative z-10 flex-shrink-0 w-12 h-12 md:w-16 md:h-16 rounded-full bg-secondary text-secondary-foreground flex items-center justify-center font-serif text-lg md:text-xl font-bold shadow-sm">
          1
        </div>
        <div class="bg-card rounded-xl p-5 shadow-sm border border-border flex-1 mt-1">
          <h3 class="font-serif text-lg font-bold text-primary">On vous appelle</h3>
          <p class="mt-1 text-sm text-muted-foreground">10 minutes, on pose des questions simples sur votre entreprise, vos services et votre territoire.</p>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="relative flex gap-4 md:gap-6 pb-8">
        <div class="relative z-10 flex-shrink-0 w-12 h-12 md:w-16 md:h-16 rounded-full bg-blue-100 text-primary flex items-center justify-center font-serif text-lg md:text-xl font-bold shadow-sm">
          2
        </div>
        <div class="bg-card rounded-xl p-5 shadow-sm border border-border flex-1 mt-1">
          <h3 class="font-serif text-lg font-bold text-primary">On configure votre assistant</h3>
          <p class="mt-1 text-sm text-muted-foreground">Vos heures, vos services de garde, votre façon de parler. On le programme sur mesure pour vous.</p>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="relative flex gap-4 md:gap-6 pb-8">
        <div class="relative z-10 flex-shrink-0 w-12 h-12 md:w-16 md:h-16 rounded-full bg-blue-100 text-primary flex items-center justify-center font-serif text-lg md:text-xl font-bold shadow-sm">
          3
        </div>
        <div class="bg-card rounded-xl p-5 shadow-sm border border-border flex-1 mt-1">
          <h3 class="font-serif text-lg font-bold text-primary">Le paiement est simple</h3>
          <p class="mt-1 text-sm text-muted-foreground">On gère le paiement par virement Interac ou carte de crédit, simple et direct.</p>
        </div>
      </div>

      <!-- Step 4 -->
      <div class="relative flex gap-4 md:gap-6">
        <div class="relative z-10 flex-shrink-0 w-12 h-12 md:w-16 md:h-16 rounded-full bg-accent text-accent-foreground flex items-center justify-center font-serif text-lg md:text-xl font-bold shadow-sm">
          4
        </div>
        <div class="bg-card rounded-xl p-5 shadow-sm border-2 border-accent/30 flex-1 mt-1">
          <h3 class="font-serif text-lg font-bold text-primary">Votre assistant est en ligne</h3>
          <p class="mt-1 text-sm text-muted-foreground">On vous fournit le numéro, et vos clients peuvent commencer à texter dès ce soir.</p>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-14 text-center">
      <a href="/contact" class="group inline-flex items-center justify-center px-12 py-5 text-lg font-semibold rounded-full bg-accent text-accent-foreground hover:bg-accent-hover transition-colors shadow-xl">
        Commencer maintenant
        <svg class="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
      <p class="mt-3 text-sm text-muted-foreground">30 jours sans risque. Satisfait ou remboursé.</p>
    </div>
  </div>
</section>
