---
import Base from '../layouts/Base.astro';
---

<Base title="Contact — Montferrand" description="Contactez Jonathan pour mettre en place votre assistant SMS Montferrand.">
  <section class="pt-24 md:pt-32 pb-20 md:pb-28">
    <div class="mx-auto max-w-6xl px-4 md:px-8">
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-primary text-center tracking-tight">Contactez-nous</h1>
      <p class="mt-3 text-center text-muted-foreground max-w-lg mx-auto">
        Prêt à configurer votre assistant ou vous avez des questions? Écrivez-nous.
      </p>

      <div class="mt-14 grid grid-cols-1 md:grid-cols-2 gap-10">

        <!-- Left: Contact info -->
        <div class="space-y-6">
          <div class="bg-card rounded-xl p-6 shadow-sm border border-border flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-blue-50 text-secondary flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-serif font-bold text-primary">Téléphone</h3>
              <a href="tel:5145550199" class="text-sm text-secondary font-medium">514-555-0199</a>
            </div>
          </div>

          <div class="bg-card rounded-xl p-6 shadow-sm border border-border flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-blue-50 text-secondary flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <h3 class="font-serif font-bold text-primary">Courriel</h3>
              <a href="mailto:bonjour@montferrand.ca?subject=Montferrand%20-%20Demande%20d'information" class="text-sm text-secondary font-medium">bonjour@montferrand.ca</a>
            </div>
          </div>

          <div class="bg-card rounded-xl p-6 shadow-sm border border-border flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-blue-50 text-secondary flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <h3 class="font-serif font-bold text-primary">Emplacement</h3>
              <p class="text-sm text-muted-foreground">Longueuil, Québec</p>
            </div>
          </div>

          <div class="bg-card rounded-xl p-6 shadow-sm border border-border flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-blue-50 text-secondary flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <h3 class="font-serif font-bold text-primary">Heures d'ouverture</h3>
              <p class="text-sm text-muted-foreground">Lundi au Vendredi, 8h00 à 17h00</p>
              <p class="text-xs text-accent font-medium mt-1">Votre assistant Montferrand, lui, travaille 24/7. 😉</p>
            </div>
          </div>
        </div>

        <!-- Right: Contact form -->
        <div class="bg-card rounded-xl p-6 md:p-8 shadow-sm border border-border">
          <form id="contact-form" class="space-y-4">
            <div>
              <label for="name" class="block text-sm font-medium text-foreground mb-1">Nom complet</label>
              <input type="text" id="name" name="name" placeholder="Jos Montferrand" required
                class="w-full px-4 py-2.5 text-sm rounded-lg border border-border bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring/50" />
            </div>
            <div>
              <label for="business" class="block text-sm font-medium text-foreground mb-1">Nom de l'entreprise</label>
              <input type="text" id="business" name="business" placeholder="Plomberie Tremblay"
                class="w-full px-4 py-2.5 text-sm rounded-lg border border-border bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring/50" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-foreground mb-1">Courriel</label>
              <input type="email" id="email" name="email" placeholder="jos@plomberie.ca" required
                class="w-full px-4 py-2.5 text-sm rounded-lg border border-border bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring/50" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-foreground mb-1">Téléphone</label>
              <input type="tel" id="phone" name="phone" placeholder="514-555-0000"
                class="w-full px-4 py-2.5 text-sm rounded-lg border border-border bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring/50" />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-foreground mb-1">Message</label>
              <textarea id="message" name="message" rows="4" placeholder="Comment pouvons-nous vous aider?"
                class="w-full px-4 py-2.5 text-sm rounded-lg border border-border bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring/50 resize-none"></textarea>
            </div>
            <button type="submit" id="contact-submit"
              class="w-full px-6 py-3 text-sm font-semibold rounded-full bg-accent text-accent-foreground hover:bg-accent-hover transition-colors cursor-pointer">
              Envoyer le message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submit = document.getElementById('contact-submit') as HTMLButtonElement;
  if (form && submit) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      submit.textContent = 'Envoi en cours...';
      submit.disabled = true;
      // Mock submission
      setTimeout(() => {
        submit.textContent = 'Message envoyé!';
        form.reset();
        setTimeout(() => {
          submit.textContent = 'Envoyer le message';
          submit.disabled = false;
        }, 2000);
      }, 1000);
    });
  }
</script>
